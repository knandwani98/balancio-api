{
  "name": "balancio-backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bunx prisma generate && tsx watch src/index.ts",
    "build": "bun install && bunx prisma generate && tsc",
    "start": "node dist/index.js",
    "postinstall": "bunx prisma generate",
    "db:generate": "bunx prisma generate",
    "db:migrate": "bunx prisma migrate deploy",
    "db:dev": "bunx prisma migrate dev",
    "db:push": "bunx prisma db push",
    "db:deploy": "sh scripts/db-deploy.sh",
    "db:studio": "bunx prisma studio"
  },
  "dependencies": {
    "@clerk/backend": "^1.21.0",
    "@prisma/client": "^6.19.3",
    "prisma": "^6.19.3",
    "@sentry/node": "^10.47.0",
    "cors": "^2.8.5",
    "dotenv": "^17.4.0",
    "express": "^4.21.2",
    "multer": "^1.4.5-lts.1",
    "pdf-parse": "^1.1.1",
    "svix": "^1.90.0",
    "typescript": "^5.7.2",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.10.5",
    "tsx": "^4.19.2"
  }
}
