PORT=3001
CLERK_SECRET_KEY=sk_test_...
# Clerk Dashboard → Webhooks → Endpoint URL https://<api-host>/webhooks/clerk → copy signing secret
# CLERK_WEBHOOK_SIGNING_SECRET=whsec_...
FRONTEND_URL=http://localhost:3000
# Optional: protect GET /internal/due-soon
# INTERNAL_CRON_SECRET=your-random-secret

# Neon + Prisma: pooled URL for the app (hostname contains "-pooler")
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxxx-pooler.region.aws.neon.tech/neondb?sslmode=require"
# Same branch, direct (non-pooler) host — required for prisma migrate
DIRECT_URL="postgresql://USER:PASSWORD@ep-xxxx.region.aws.neon.tech/neondb?sslmode=require"

# Production (Neon): use the prod branch pooler for DATABASE_URL and the non-pooler host for DIRECT_URL, e.g.
# DATABASE_URL="postgresql://USER:PASSWORD@ep-wispy-base-an7t6bjk-pooler.c-6.us-east-1.aws.neon.tech/neondb?sslmode=require"
# DIRECT_URL="postgresql://USER:PASSWORD@ep-wispy-base-an7t6bjk.c-6.us-east-1.aws.neon.tech/neondb?sslmode=require"
