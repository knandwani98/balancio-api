generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum TransactionType {
  income
  expense
}

enum BudgetRecurrence {
  monthly
  yearly
  quarterly
  half_yearly
  weekly
  daily
  one_time
}

enum AuthLoginType {
  email
  google
  apple
  github
  microsoft
  other
}

enum ProjectRole {
  admin
  member
}

enum ProjectInvitationStatus {
  SENT
  ACCEPTED
  REVOKED
  DENIED
}

enum CategoryKind {
  expense
  income
  neutral
}

enum PaymentMethod {
  cash
  bank
  cards
  stocks
  wallet
}

enum TransactionLineStatus {
  pending
  cleared
  failed
}

enum CardAccountType {
  credit
  debit
}

enum BankAccountType {
  savings
  current
}

enum GoalTenureMode {
  infinite
  fixed_days
  aim
}

enum PlanFundInputMode {
  percentage
  amount
}

model User {
  id              String         @id
  email           String?
  email_verified  Boolean        @default(false)
  phone           String?
  first_name      String?
  last_name       String?
  username        String?
  avatar_url      String?
  login_type      AuthLoginType  @default(email)
  created_at      DateTime       @default(now()) @db.Timestamptz(6)
  updated_at      DateTime       @default(now()) @updatedAt @db.Timestamptz(6)

  projects_created        Project[]           @relation("ProjectCreator")
  project_memberships     ProjectMember[]
  invitations_sent        ProjectInvitation[] @relation("InvitationInviter")
  categories_created      Category[]          @relation("CategoryCreator")
  budgets_created         Budget[]            @relation("BudgetCreator")
  transactions_created    Transaction[]       @relation("TransactionCreator")
  goals_created           Goal[]              @relation("GoalCreator")
  investment_plans_created InvestmentPlan[]   @relation("InvestmentPlanCreator")
  bank_accounts_created   BankAccount[]       @relation("BankAccountCreator")
  cards                   Card[]
  wallets                 Wallet[]
  transactions_owned      Transaction[]       @relation("TransactionOwner")

  @@map("user")
}

model Project {
  id                 String   @id @default(uuid()) @db.Uuid
  name               String
  description        String?
  icon_url           String?
  is_archive         Boolean  @default(false)
  created_by_user_id String
  created_at         DateTime @default(now()) @db.Timestamptz(6)
  updated_at         DateTime @default(now()) @updatedAt @db.Timestamptz(6)

  creator      User                 @relation("ProjectCreator", fields: [created_by_user_id], references: [id], onDelete: Restrict)
  members      ProjectMember[]
  invitations  ProjectInvitation[]
  categories   Category[]
  budgets              Budget[]
  transactions         Transaction[]
  goals                Goal[]
  investment_plans     InvestmentPlan[]

  @@index([created_by_user_id])
  @@map("project")
}

model ProjectMember {
  id         String      @id @default(uuid()) @db.Uuid
  project_id String      @db.Uuid
  user_id    String
  role       ProjectRole @default(member)
  created_at DateTime    @default(now()) @db.Timestamptz(6)
  updated_at DateTime    @default(now()) @updatedAt @db.Timestamptz(6)

  project Project @relation(fields: [project_id], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([project_id, user_id])
  @@index([user_id])
  @@map("project_member")
}

model ProjectInvitation {
  id                 String                    @id @default(uuid()) @db.Uuid
  project_id         String                    @db.Uuid
  email_normalized   String
  status             ProjectInvitationStatus   @default(SENT)
  invited_by_user_id String
  created_at         DateTime                  @default(now()) @db.Timestamptz(6)
  updated_at         DateTime                  @default(now()) @updatedAt @db.Timestamptz(6)
  responded_at       DateTime?                 @db.Timestamptz(6)

  project    Project @relation(fields: [project_id], references: [id], onDelete: Cascade)
  invited_by User    @relation("InvitationInviter", fields: [invited_by_user_id], references: [id], onDelete: Cascade)

  @@index([project_id])
  @@index([email_normalized, status])
  @@map("project_invitation")
}

model Category {
  id                 String       @id @default(uuid()) @db.Uuid
  project_id         String       @db.Uuid
  name               String
  icon               String
  kind               CategoryKind
  created_by_user_id String
  created_at         DateTime     @default(now()) @db.Timestamptz(6)
  updated_at         DateTime     @default(now()) @updatedAt @db.Timestamptz(6)

  project      Project       @relation(fields: [project_id], references: [id], onDelete: Cascade)
  created_by   User          @relation("CategoryCreator", fields: [created_by_user_id], references: [id], onDelete: Restrict)
  budgets      Budget[]
  transactions Transaction[]

  @@unique([project_id, name, kind])
  @@index([project_id])
  @@map("category")
}

model Budget {
  id                           String           @id @default(uuid()) @db.Uuid
  project_id                   String           @db.Uuid
  created_by_user_id           String
  category_id                  String           @db.Uuid
  title                        String
  default_planned_amount Decimal @db.Decimal(19, 4)
  start_date                   DateTime         @db.Date
  recurrence_end_date          DateTime?        @db.Date
  due_day_of_occurence         Int              @db.SmallInt
  recurrence                   BudgetRecurrence @default(monthly)
  payment_method               PaymentMethod    @default(cash)
  bank_account_id              String?          @db.Uuid
  card_id                      String?          @db.Uuid
  wallet_id                    String?          @db.Uuid
  created_at                   DateTime         @default(now()) @db.Timestamptz(6)
  updated_at                   DateTime         @default(now()) @updatedAt @db.Timestamptz(6)

  project      Project       @relation(fields: [project_id], references: [id], onDelete: Cascade)
  created_by   User          @relation("BudgetCreator", fields: [created_by_user_id], references: [id], onDelete: Restrict)
  category     Category      @relation(fields: [category_id], references: [id], onDelete: Restrict)
  bank_account BankAccount?  @relation(fields: [bank_account_id], references: [id], onDelete: SetNull)
  card         Card?         @relation(fields: [card_id], references: [id], onDelete: SetNull)
  wallet       Wallet?       @relation(fields: [wallet_id], references: [id], onDelete: SetNull)
  transactions Transaction[] @relation("BudgetPeriodTransactions")

  @@index([project_id])
  @@index([category_id])
  @@map("budget")
}

model Transaction {
  id                   String                 @id @default(uuid()) @db.Uuid
  project_id           String                 @db.Uuid
  created_by_user_id   String
  user_id              String
  type                 TransactionType
  name                 String
  amount         Decimal @db.Decimal(19, 4)
  line_status          TransactionLineStatus  @default(pending)
  payment_method       PaymentMethod          @default(cash)
  occurred_at          DateTime               @db.Date
  category_id       String?   @db.Uuid
  note              String?
  reference_details String?   @db.VarChar(500)
  /** Position on bank statement PDF (0 = first row); set on import. */
  statement_order   Int?
  budget_id         String?   @db.Uuid
  due_date       DateTime? @db.Date
  bank_account_id String?  @db.Uuid
  card_id        String?   @db.Uuid
  wallet_id      String?   @db.Uuid
  created_at     DateTime  @default(now()) @db.Timestamptz(6)
  updated_at     DateTime  @default(now()) @updatedAt @db.Timestamptz(6)

  project    Project      @relation(fields: [project_id], references: [id], onDelete: Cascade)
  created_by User         @relation("TransactionCreator", fields: [created_by_user_id], references: [id], onDelete: Restrict)
  owner      User         @relation("TransactionOwner", fields: [user_id], references: [id], onDelete: Cascade)
  category   Category?    @relation(fields: [category_id], references: [id], onDelete: SetNull)
  budget     Budget?      @relation("BudgetPeriodTransactions", fields: [budget_id], references: [id], onDelete: Cascade)
  bank_account BankAccount? @relation(fields: [bank_account_id], references: [id], onDelete: SetNull)
  card       Card?        @relation(fields: [card_id], references: [id], onDelete: SetNull)
  wallet     Wallet?      @relation(fields: [wallet_id], references: [id], onDelete: SetNull)

  @@unique([budget_id, due_date])
  @@index([project_id])
  @@index([user_id])
  @@index([occurred_at])
  @@index([project_id, occurred_at, statement_order])
  @@index([category_id])
  @@index([budget_id])
  @@index([due_date])
  @@map("transaction")
}

model Goal {
  id                     String          @id @default(uuid()) @db.Uuid
  project_id             String          @db.Uuid
  created_by_user_id     String
  name                   String
  amount           Decimal @db.Decimal(19, 4)
  frequency              BudgetRecurrence
  tenure_mode            GoalTenureMode
  fixed_days             Int?
  aim_amount       Decimal? @db.Decimal(19, 4)
  source                 PaymentMethod
  interest_rate_pa       Decimal?        @db.Decimal(5, 2)
  start_date             DateTime?       @db.Date
  maturity_date          DateTime?       @db.Date
  linked_bank_account_id String?         @db.Uuid
  is_archived            Boolean         @default(false)
  created_at             DateTime        @default(now()) @db.Timestamptz(6)
  updated_at             DateTime        @default(now()) @updatedAt @db.Timestamptz(6)

  project             Project      @relation(fields: [project_id], references: [id], onDelete: Cascade)
  created_by          User         @relation("GoalCreator", fields: [created_by_user_id], references: [id], onDelete: Restrict)
  linked_bank_account BankAccount? @relation(fields: [linked_bank_account_id], references: [id], onDelete: SetNull)

  @@index([project_id])
  @@map("goal")
}

model BankAccount {
  id              String          @id @default(uuid()) @db.Uuid
  createdBy       String          @map("created_by")
  bank_id         String?
  bank_name       String
  nickname        String?
  account_number  Int
  account_type    BankAccountType @default(savings)
  current_balance Decimal         @default(0) @db.Decimal(19, 4)
  icon_url        String?
  created_at      DateTime @default(now()) @db.Timestamptz(6)
  updated_at      DateTime @default(now()) @updatedAt @db.Timestamptz(6)

  creator      User          @relation("BankAccountCreator", fields: [createdBy], references: [id], onDelete: Cascade)
  transactions Transaction[]
  goals        Goal[]
  budgets      Budget[]

  @@index([createdBy])
  @@map("bank_account")
}

model Card {
  id         String          @id @default(uuid()) @db.Uuid
  user_id    String
  bank_id    String?
  bank_name  String
  card_type  CardAccountType
  last4      String
  brand      String
  nickname   String?
  icon_url   String?
  created_at DateTime        @default(now()) @db.Timestamptz(6)
  updated_at DateTime        @default(now()) @updatedAt @db.Timestamptz(6)

  user         User          @relation(fields: [user_id], references: [id], onDelete: Cascade)
  transactions Transaction[]
  budgets      Budget[]

  @@index([user_id])
  @@map("card")
}

model Wallet {
  id              String   @id @default(uuid()) @db.Uuid
  user_id         String
  name            String
  nickname        String?
  current_balance Decimal  @default(0) @db.Decimal(19, 4)
  created_at      DateTime @default(now()) @db.Timestamptz(6)
  updated_at      DateTime @default(now()) @updatedAt @db.Timestamptz(6)

  user         User          @relation(fields: [user_id], references: [id], onDelete: Cascade)
  transactions Transaction[]
  budgets      Budget[]

  @@index([user_id])
  @@map("wallet")
}

model InvestmentPlan {
  id                 String           @id @default(uuid()) @db.Uuid
  project_id         String           @db.Uuid
  created_by_user_id String
  name               String
  start_date         DateTime         @db.Date
  end_date           DateTime?        @db.Date
  period_amount      Decimal          @db.Decimal(19, 4)
  frequency          BudgetRecurrence @default(monthly)
  created_at         DateTime         @default(now()) @db.Timestamptz(6)
  updated_at         DateTime         @updatedAt @db.Timestamptz(6)

  project    Project             @relation(fields: [project_id], references: [id], onDelete: Cascade)
  created_by User                @relation("InvestmentPlanCreator", fields: [created_by_user_id], references: [id], onDelete: Restrict)
  points     PlanTimelinePoint[]

  @@index([project_id])
  @@map("investment_plan")
}

model PlanTimelinePoint {
  id             String    @id @default(uuid()) @db.Uuid
  plan_id        String    @db.Uuid
  effective_from DateTime  @db.Date
  effective_to   DateTime? @db.Date
  period_amount  Decimal   @db.Decimal(19, 4)
  created_at     DateTime  @default(now()) @db.Timestamptz(6)
  updated_at     DateTime  @updatedAt @db.Timestamptz(6)

  plan  InvestmentPlan @relation(fields: [plan_id], references: [id], onDelete: Cascade)
  funds PlanFund[]

  @@index([plan_id, effective_from])
  @@map("plan_timeline_point")
}

model PlanFund {
  id          String            @id @default(uuid()) @db.Uuid
  point_id    String            @db.Uuid
  name        String
  percentage  Decimal           @db.Decimal(7, 4)
  input_mode  PlanFundInputMode @default(percentage)
  sort_order  Int               @default(0)

  point PlanTimelinePoint @relation(fields: [point_id], references: [id], onDelete: Cascade)

  @@index([point_id])
  @@map("plan_fund")
}
